{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "generated/prisma/client\\.js": "<rootDir>/__mocks__/prisma-client.ts",
    "generated/prisma/client": "<rootDir>/__mocks__/prisma-client.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
