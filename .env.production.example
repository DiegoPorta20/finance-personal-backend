# Copia este archivo como `.env.production` EN EL EC2 (no se commitea).
# Genera secretos fuertes:  openssl rand -base64 32

DB_USER=finanzas
DB_PASSWORD=CAMBIA_ESTO_password_fuerte
DB_NAME=finanzas_db

# El host es `mysql` (nombre del servicio en docker-compose), no localhost.
DATABASE_URL=mysql://finanzas:CAMBIA_ESTO_password_fuerte@mysql:3306/finanzas_db

JWT_SECRET=CAMBIA_ESTO_cadena_larga_y_aleatoria
JWT_EXPIRES_IN=7d
PORT=3000
